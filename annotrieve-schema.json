{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CustomAnnotation",
  "description": "Annotrieve Favorites import record (offline export from gffy)",
  "type": "object",
  "required": [
    "kind",
    "annotation_id",
    "custom_name",
    "uploaded_md5",
    "uploaded_at",
    "uploaded_file_size",
    "features_summary"
  ],
  "additionalProperties": true,
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["custom"]
    },
    "annotation_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "custom_name": {
      "type": "string",
      "minLength": 1
    },
    "uploaded_md5": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "uploaded_at": {
      "type": "string",
      "minLength": 1
    },
    "uploaded_file_size": {
      "type": "integer",
      "minimum": 0
    },
    "features_summary": {
      "type": "object",
      "required": ["types", "sources"],
      "properties": {
        "attribute_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "types": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "biotypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "root_type_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "types_missing_id": {
          "type": "array",
          "items": { "type": "string" }
        },
        "has_biotype": { "type": "boolean" },
        "has_cds": { "type": "boolean" },
        "has_exon": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "features_statistics": {
      "type": "object",
      "required": ["gene_category_stats", "transcript_type_stats"],
      "properties": {
        "gene_category_stats": {
          "type": "object",
          "patternProperties": {
            "^(coding|pseudogene|non_coding)$": {
              "$ref": "#/definitions/geneCategoryFeatureStats"
            }
          },
          "additionalProperties": false
        },
        "transcript_type_stats": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "$ref": "#/definitions/genericTranscriptTypeStats"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "genericLengthStats": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 },
        "mean": { "type": "number", "minimum": 0 }
      },
      "required": ["min", "max", "mean"],
      "additionalProperties": false
    },
    "geneCategoryFeatureStats": {
      "type": "object",
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "length_stats": { "$ref": "#/definitions/genericLengthStats" },
        "biotype_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "transcript_type_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "required": [
        "total_count",
        "length_stats",
        "biotype_counts",
        "transcript_type_counts"
      ],
      "additionalProperties": false
    },
    "subFeatureStats": {
      "type": "object",
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "length": { "$ref": "#/definitions/genericLengthStats" },
        "concatenated_length": { "$ref": "#/definitions/genericLengthStats" }
      },
      "required": ["total_count", "length"],
      "additionalProperties": false
    },
    "associatedGenesStats": {
      "type": "object",
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "gene_categories": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "required": ["total_count", "gene_categories"],
      "additionalProperties": false
    },
    "genericTranscriptTypeStats": {
      "type": "object",
      "properties": {
        "length_stats": { "$ref": "#/definitions/genericLengthStats" },
        "total_count": { "type": "integer", "minimum": 0 },
        "biotype_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "associated_genes": { "$ref": "#/definitions/associatedGenesStats" },
        "exon_stats": { "$ref": "#/definitions/subFeatureStats" },
        "cds_stats": { "$ref": "#/definitions/subFeatureStats" }
      },
      "required": [
        "length_stats",
        "total_count",
        "biotype_counts",
        "associated_genes",
        "exon_stats"
      ],
      "additionalProperties": false
    }
  }
}
